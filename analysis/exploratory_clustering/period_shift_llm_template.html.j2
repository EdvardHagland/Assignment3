<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <script>{{ plotly_js | safe }}</script>
  <style>
    :root {
      --ink: #1a2a35;
      --ink-soft: #425868;
      --muted: #687987;
      --faint: #95a4ae;
      --paper: #f5f1e7;
      --card: #fffdf8;
      --line: #ddd1be;
      --line-soft: #ece3d5;
      --accent: #0f4c5c;
      --teal: #1b998b;
      --warm: #c56b3c;
      --olive: #5a8a3e;
      --blue: #3e6c8f;
      --shadow: 0 2px 8px rgba(19, 33, 44, 0.05), 0 12px 28px rgba(19, 33, 44, 0.07);
      --r: 18px;
      --r-lg: 24px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: 56px; }
    body {
      margin: 0;
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: radial-gradient(circle at top right, rgba(15, 76, 92, 0.06), transparent 28%), var(--paper);
      line-height: 1.6;
    }

    .accent-bar {
      height: 4px;
      background: linear-gradient(90deg, var(--accent), var(--teal), var(--warm));
    }

    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      gap: 8px;
      padding: 12px 18px;
      background: rgba(245, 241, 231, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line-soft);
      overflow-x: auto;
    }

    .nav a {
      text-decoration: none;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 700;
      padding: 6px 12px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .nav a:hover, .nav a.active {
      background: rgba(15, 76, 92, 0.10);
      color: var(--accent);
    }

    .page {
      max-width: 1340px;
      margin: 0 auto;
      padding: 28px 22px 80px;
    }

    .hero, .section, .abstract-card {
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow);
    }

    .hero {
      padding: 40px 44px;
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      right: -72px;
      bottom: -96px;
      width: 250px;
      height: 250px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(15, 76, 92, 0.09), transparent 65%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-block;
      padding: 5px 12px;
      border-radius: 999px;
      background: rgba(15, 76, 92, 0.08);
      color: var(--accent);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 14px 0 10px;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: clamp(2rem, 3.7vw, 3.2rem);
      line-height: 1.08;
    }

    .subtitle {
      max-width: 68ch;
      color: var(--muted);
      font-size: 1rem;
    }

    .hero-meta {
      margin-top: 24px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
      gap: 12px;
    }

    .metric {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.90);
      border: 1px solid var(--line-soft);
    }

    .metric-label {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
    }

    .metric-value {
      margin-top: 4px;
      font-size: 1.32rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
      word-break: break-word;
    }

    .abstract-card {
      margin-top: 20px;
      padding: 26px 30px;
      background: linear-gradient(145deg, rgba(15, 76, 92, 0.04), rgba(255, 255, 255, 0.88));
    }

    .abstract-card h2 {
      margin: 0;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 1.5rem;
    }

    .abstract-card p {
      margin: 10px 0 0;
      color: var(--ink-soft);
      font-size: 0.96rem;
    }

    .abstract-lists {
      margin-top: 16px;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .abstract-box {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid var(--line-soft);
    }

    .abstract-box h3 {
      margin: 0 0 8px;
      font-size: 0.86rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .abstract-box ul {
      margin: 0;
      padding-left: 18px;
      color: var(--ink-soft);
      font-size: 0.9rem;
    }

    .section {
      margin-top: 20px;
      padding: 28px 32px;
    }

    .section-header {
      margin-bottom: 20px;
    }

    .section-header h2 {
      margin: 0;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 1.42rem;
    }

    .section-header p {
      margin: 8px 0 0;
      max-width: 76ch;
      color: var(--muted);
      font-size: 0.94rem;
    }

    .subsection-head {
      margin: 6px 0 14px;
    }

    .subsection-head h3 {
      margin: 0;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 1.14rem;
    }

    .subsection-head p {
      margin: 6px 0 0;
      max-width: 72ch;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .empty-note {
      padding: 16px 18px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px dashed var(--line);
      color: var(--muted);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .figure-card {
      padding: 14px;
      border-radius: var(--r);
      background: var(--card);
      border: 1px solid var(--line-soft);
    }

    .figure-card .plotly-graph-div {
      width: 100% !important;
    }

    .clusters {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(390px, 1fr));
      gap: 16px;
    }

    .cluster-card {
      border-radius: var(--r);
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-top: 4px solid var(--line);
    }

    article.cluster-card {
      padding: 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    details.cluster-card {
      overflow: hidden;
    }

    .cluster-card[data-kind="new_post_only"] { border-top-color: var(--accent); }
    .cluster-card[data-kind="split/refined"] { border-top-color: var(--teal); }
    .cluster-card[data-kind="merged"] { border-top-color: var(--warm); }
    .cluster-card[data-kind="persistent"] { border-top-color: var(--olive); }
    .cluster-card[data-kind="approximate_overlap"] { border-top-color: var(--blue); }

    .cluster-summary {
      list-style: none;
      cursor: pointer;
      padding: 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      position: relative;
      padding-right: 88px;
    }

    .cluster-summary::-webkit-details-marker {
      display: none;
    }

    .cluster-summary::after {
      content: "Expand";
      position: absolute;
      top: 22px;
      right: 22px;
      font-size: 0.68rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
    }

    details.cluster-card[open] .cluster-summary {
      border-bottom: 1px solid var(--line-soft);
    }

    details.cluster-card[open] .cluster-summary::after {
      content: "Collapse";
    }

    .cluster-card-body {
      padding: 0 22px 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .cluster-head {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-start;
    }

    .cluster-head h3 {
      margin: 0;
      font-size: 1.08rem;
    }

    .cluster-meta {
      text-align: right;
      font-size: 0.8rem;
      color: var(--muted);
      font-weight: 700;
    }

    .cluster-summary-title {
      margin-top: 4px;
      font-size: 0.9rem;
      color: var(--ink-soft);
      font-weight: 700;
    }

    .cluster-summary-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      background: rgba(15, 76, 92, 0.10);
      color: var(--accent);
    }

    .summary-chip {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      background: rgba(66, 88, 104, 0.08);
      color: var(--muted);
    }

    .cluster-summary-headline {
      margin: 0;
      font-size: 0.93rem;
      color: var(--ink-soft);
    }

    .cluster-summary-headline strong {
      color: var(--ink);
    }

    .summary-inline-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 14px;
      font-size: 0.8rem;
      color: var(--muted);
    }

    .summary-inline-stats strong {
      color: var(--faint);
      font-size: 0.68rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-right: 4px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .stat-box {
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(15, 76, 92, 0.05);
    }

    .stat-box strong {
      display: block;
      font-size: 0.68rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--faint);
      margin-bottom: 2px;
    }

    .stat-box span {
      font-size: 1rem;
      font-weight: 800;
    }

    .analysis-box {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(27, 153, 139, 0.06);
      border: 1px solid rgba(27, 153, 139, 0.14);
    }

    .analysis-box h4 {
      margin: 0 0 6px;
      font-size: 0.94rem;
    }

    .analysis-box p {
      margin: 0;
      font-size: 0.91rem;
      color: var(--ink-soft);
    }

    .cluster-text {
      font-size: 0.9rem;
      color: var(--ink-soft);
    }

    .cluster-text strong {
      color: var(--muted);
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .bullet-list {
      margin: 0;
      padding-left: 18px;
      color: var(--ink-soft);
      font-size: 0.9rem;
    }

    .evidence-grid {
      display: grid;
      gap: 10px;
    }

    .evidence-group {
      padding: 12px;
      border-radius: 14px;
      background: rgba(245, 241, 231, 0.86);
      border: 1px solid var(--line-soft);
    }

    .evidence-group h5 {
      margin: 0 0 8px;
      font-size: 0.76rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .evidence-group summary {
      list-style: none;
      cursor: pointer;
      margin: 0;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .evidence-group summary::-webkit-details-marker {
      display: none;
    }

    .evidence-group summary::after {
      content: "Show";
      float: right;
      font-size: 0.68rem;
      color: var(--muted);
    }

    .evidence-group[open] summary {
      margin-bottom: 8px;
    }

    .evidence-group[open] summary::after {
      content: "Hide";
    }

    .example {
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.82);
      border-left: 3px solid var(--line);
      margin-top: 8px;
    }

    .example-meta {
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--faint);
    }

    .example p {
      margin: 5px 0 0;
      font-size: 0.87rem;
      color: var(--ink-soft);
    }

    details summary {
      cursor: pointer;
      font-weight: 700;
      color: var(--accent);
    }

    .footer {
      margin-top: 24px;
      text-align: center;
      color: var(--faint);
      font-size: 0.84rem;
    }

    .footer code {
      background: rgba(15, 76, 92, 0.06);
      padding: 2px 6px;
      border-radius: 6px;
    }

    @media (max-width: 960px) {
      .page { padding: 16px 12px 60px; }
      .hero { padding: 28px 22px; }
      .section { padding: 22px 18px; }
      .grid-2, .abstract-lists { grid-template-columns: 1fr; }
      .clusters { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="accent-bar"></div>
  <nav class="nav">
    <a href="#overview">Overview</a>
    <a href="#question">Question & Method</a>
    <a href="#answer">Answer</a>
    <a href="#clusters">Findings</a>
    <a href="#appendix">Appendix</a>
    <a href="#catalog">Catalog</a>
  </nav>

  {% macro render_cluster_card(cluster) -%}
  <details class="cluster-card" data-kind="{{ cluster.match_type }}">
    <summary class="cluster-summary">
      <div class="cluster-head">
        <div>
          <h3>{{ cluster.post_cluster_label }}</h3>
          <div class="cluster-summary-title">{{ cluster.analysis.card_title }}</div>
        </div>
        <div class="cluster-meta">{{ cluster.cluster_size }} rows<br>{{ cluster.ticker_count }} tickers<br>{{ cluster.filing_count }} filings</div>
      </div>
      <div class="cluster-summary-tags">
        <span class="badge">{{ cluster.match_label }}</span>
        <span class="summary-chip">{{ cluster.continuity_label }}</span>
        <span class="summary-chip">{{ cluster.count_gap_role_label }}</span>
      </div>
      <p class="cluster-summary-headline"><strong>{{ cluster.analysis.headline }}</strong> {{ cluster.analysis.continuity_note }}</p>
      <div class="summary-inline-stats">
        <span><strong>Post share</strong> {{ "%.1f"|format(cluster.period_share * 100) }}%</span>
        <span><strong>Best cosine</strong> {% if cluster.best_pre_similarity == cluster.best_pre_similarity %}{{ "%.2f"|format(cluster.best_pre_similarity) }}{% else %}n/a{% endif %}</span>
        <span><strong>Match</strong> {{ cluster.best_pre_cluster_label or "none" }}</span>
        <span><strong>Confidence</strong> {{ cluster.analysis.confidence }}</span>
      </div>
    </summary>

    <div class="cluster-card-body">
      <div class="analysis-box">
        <h4>{{ cluster.analysis.card_title }}</h4>
        <p><strong>{{ cluster.analysis.headline }}</strong> {{ cluster.analysis.interpretation }}</p>
      </div>

      <div class="stats">
        <div class="stat-box"><strong>Post share</strong><span>{{ "%.1f"|format(cluster.period_share * 100) }}%</span></div>
        <div class="stat-box"><strong>Best cosine</strong><span>{% if cluster.best_pre_similarity == cluster.best_pre_similarity %}{{ "%.2f"|format(cluster.best_pre_similarity) }}{% else %}n/a{% endif %}</span></div>
        <div class="stat-box"><strong>Match</strong><span>{{ cluster.best_pre_cluster_label or "none" }}</span></div>
        <div class="stat-box"><strong>Confidence</strong><span>{{ cluster.analysis.confidence }}</span></div>
        <div class="stat-box"><strong>Top-ticker share</strong><span>{{ "%.0f"|format(cluster.top_ticker_share * 100) }}%</span></div>
        <div class="stat-box"><strong>Prime / Supplier</strong><span>{{ "%.0f"|format(cluster.prime_share * 100) }}% / {{ "%.0f"|format(cluster.supplier_share * 100) }}%</span></div>
      </div>

      <div class="cluster-text"><strong>Why it was selected</strong> {{ cluster.analysis.why_interesting }}</div>
      <div class="cluster-text"><strong>Change reading</strong> {{ cluster.continuity_label }}. {{ cluster.analysis.continuity_note }}</div>
      <div class="cluster-text"><strong>Count-gap role</strong> {{ cluster.count_gap_role_label }}. {{ cluster.analysis.count_gap_note }}</div>
      {% if cluster.analysis.layer_reading %}
      <div class="cluster-text"><strong>Prime vs supplier</strong> {{ cluster.analysis.layer_reading }}</div>
      {% endif %}
      {% if cluster.analysis.concentration_note %}
      <div class="cluster-text"><strong>Concentration</strong> {{ cluster.analysis.concentration_note }}</div>
      {% endif %}
      {% if cluster.analysis.temporal_reading_post %}
      <div class="cluster-text"><strong>Temporal trajectory (post)</strong> {{ cluster.analysis.temporal_reading_post }}</div>
      {% endif %}
      {% if cluster.analysis.intra_cluster_churn_note %}
      <div class="cluster-text"><strong>Intra-cluster churn</strong> {{ cluster.analysis.intra_cluster_churn_note }}</div>
      {% endif %}
      {% if cluster.analysis.category_blending_note %}
      <div class="cluster-text"><strong>Category blending</strong> {{ cluster.analysis.category_blending_note }}</div>
      {% endif %}
      <div class="cluster-text"><strong>Post terms</strong> {{ cluster.top_terms }}</div>
      {% if cluster.best_pre_top_terms %}
      <div class="cluster-text"><strong>Best pre terms</strong> {{ cluster.best_pre_top_terms }}</div>
      {% endif %}
      {% if cluster.shared_terms %}
      <div class="cluster-text"><strong>Shared terms</strong> {{ cluster.shared_terms }}</div>
      {% endif %}
      <div class="cluster-text"><strong>Genre caveat</strong> {{ cluster.analysis.genre_caveat }}</div>

      <ul class="bullet-list">
        {% for point in cluster.analysis.evidence_points %}
        <li>{{ point }}</li>
        {% endfor %}
      </ul>

      <div class="evidence-grid">
        <details class="evidence-group">
          <summary>Core post examples ({{ cluster.central_post_examples | length }})</summary>
          {% for example in cluster.central_post_examples %}
          <div class="example">
            <div class="example-meta">{{ example.example_id }} · {{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }}</div>
            <p>{{ example.text_preview }}</p>
          </div>
          {% endfor %}
        </details>

        <details class="evidence-group">
          <summary>Mid-distance post examples ({{ cluster.mid_post_examples | length }})</summary>
          {% for example in cluster.mid_post_examples %}
          <div class="example">
            <div class="example-meta">{{ example.example_id }} · {{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }} · p={{ "%.2f"|format(example.distance_percentile) }}</div>
            <p>{{ example.text_preview }}</p>
          </div>
          {% endfor %}
        </details>

        <details class="evidence-group">
          <summary>Peripheral but still member examples ({{ cluster.peripheral_post_examples | length }})</summary>
          {% for example in cluster.peripheral_post_examples %}
          <div class="example">
            <div class="example-meta">{{ example.example_id }} · {{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }} · p={{ "%.2f"|format(example.distance_percentile) }}</div>
            <p>{{ example.text_preview }}</p>
          </div>
          {% endfor %}
        </details>

        {% if cluster.matched_pre_examples %}
        <details class="evidence-group">
          <summary>Matched pre-cluster context ({{ cluster.matched_pre_examples | length }})</summary>
          {% for example in cluster.matched_pre_examples %}
          <div class="example">
            <div class="example-meta">{{ example.example_id }} · {{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }}</div>
            <p>{{ example.text_preview }}</p>
          </div>
          {% endfor %}
        </details>
        {% endif %}
      </div>
    </div>
  </details>
  {%- endmacro %}

  <div class="page">
    <section class="hero" id="overview">
      <div class="eyebrow">LLM-assisted synthesis</div>
      <h1>{{ title }}</h1>
      <p class="subtitle">{{ subtitle }}</p>
      <div class="hero-meta">
        <div class="metric"><div class="metric-label">Narrated clusters</div><div class="metric-value">{{ summary.interesting_clusters }}</div></div>
        <div class="metric"><div class="metric-label">Emergent discoveries</div><div class="metric-value">{{ summary.emergent_discoveries }}</div></div>
        <div class="metric"><div class="metric-label">Content shifts</div><div class="metric-value">{{ summary.content_shifts }}</div></div>
        <div class="metric"><div class="metric-label">Structural shifts</div><div class="metric-value">{{ summary.structural_shifts }}</div></div>
        <div class="metric"><div class="metric-label">Cluster gap</div><div class="metric-value">{{ summary.cluster_gap }}</div></div>
        <div class="metric"><div class="metric-label">Match filters</div><div class="metric-value" style="font-size:0.95rem;">{{ summary.match_types }}</div></div>
        <div class="metric"><div class="metric-label">Companies</div><div class="metric-value">{{ summary.companies }}</div></div>
        <div class="metric"><div class="metric-label">Pre clusters</div><div class="metric-value">{{ summary.pre_clusters }}</div></div>
        <div class="metric"><div class="metric-label">Post clusters</div><div class="metric-value">{{ summary.post_clusters }}</div></div>
        <div class="metric"><div class="metric-label">Embedding model</div><div class="metric-value" style="font-size:0.92rem;">{{ summary.embedding_model }}</div></div>
        <div class="metric"><div class="metric-label">LLM model</div><div class="metric-value" style="font-size:0.92rem;">{{ summary.llm_model }}</div></div>
        <div class="metric"><div class="metric-label">Clustered rows</div><div class="metric-value">{{ summary.clustered_rows }}</div></div>
      </div>
    </section>

    <section class="section" id="question">
      <div class="section-header">
        <h2>Research Question and Method</h2>
        <p>This report is designed to answer a narrow question about disclosure change, using a method that separates thematic structure from simple row-count growth.</p>
      </div>
      <div class="abstract-lists">
        <div class="abstract-box">
          <h3>Research Question</h3>
          <p>How did the thematic structure of defense-sector SEC 10-K Item 1A risk disclosures change after 2022, and do extra post-2022 clusters reflect genuinely new risk themes, the splitting of older broad themes, or simply denser and more explicit disclosure language?</p>
        </div>
        <div class="abstract-box">
          <h3>Method</h3>
          {% if is_full_corpus_run %}
          <p>The full corpus was embedded once with the same model, then clustered separately for the pre-2022 and post-2022 subsets. Post clusters were approximately matched back to pre clusters, and Gemini was used only after that evidence layer existed, one cluster at a time, to interpret whether each selected cluster looks new, refined, shifted in contents, or largely continuous.</p>
          {% else %}
          <p>The rows included in the clustering run were embedded once with the same model, then clustered separately for the pre-2022 and post-2022 subsets. Post clusters were approximately matched back to pre clusters, and Gemini was used only after that evidence layer existed, one cluster at a time, to interpret whether each selected cluster looks new, refined, shifted in contents, or largely continuous.</p>
          {% endif %}
        </div>
      </div>
      <div class="abstract-box" style="margin-top: 14px;">
        <h3>How To Read The Result</h3>
        <p>A higher post-2022 cluster count is not treated as self-explanatory. The report explicitly asks whether the gap comes from genuinely new themes, from older themes splitting into more specific subthemes, or from the same themes being described in longer and more explicit post-2022 language.</p>
      </div>
    </section>

    <section class="section" id="answer">
      <div class="section-header">
        <h2>Answer in Brief</h2>
        <p>{{ count_shift.headline_note }}</p>
      </div>
      <p class="cluster-text"><strong>Main answer</strong> {{ abstract_data.primary_result }}</p>
      <div class="grid-2">
        <div class="figure-card">{{ figures.cluster_count_shift | safe }}</div>
        <div class="figure-card">{{ figures.period_text_density | safe }}</div>
      </div>
      <p class="cluster-text"><strong>Structural reading</strong> {{ count_shift.decomposition_note }}</p>
      <p class="cluster-text"><strong>Broad-theme check</strong> {{ count_shift.broad_note }}</p>
      <p class="cluster-text"><strong>Volume caution</strong> {{ count_shift.volume_note }}</p>
    </section>

    <section class="abstract-card">
      <h2>Interpretive Summary</h2>
      <p>{{ abstract_data.abstract }}</p>
      {% if abstract_data.boilerplate_envelope_finding %}
      <div class="abstract-box" style="margin-top: 14px;">
        <h3>Boilerplate-envelope reading</h3>
        <p>{{ abstract_data.boilerplate_envelope_finding }}</p>
      </div>
      {% endif %}
      <div class="abstract-lists">
        <div class="abstract-box">
          <h3>Major Findings</h3>
          <ul>
            {% for finding in abstract_data.major_findings %}
            <li>{{ finding }}</li>
            {% endfor %}
          </ul>
        </div>
        <div class="abstract-box">
          <h3>Limitations</h3>
          <ul>
            {% for limitation in abstract_data.limitations %}
            <li>{{ limitation }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% if abstract_data.layer_asymmetries %}
      <div class="abstract-box" style="margin-top: 14px;">
        <h3>Prime vs supplier asymmetries</h3>
        <ul>
          {% for item in abstract_data.layer_asymmetries %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if abstract_data.intra_cluster_churn_caveat %}
      <div class="abstract-box" style="margin-top: 14px;">
        <h3>Intra-cluster churn caveat</h3>
        <p>{{ abstract_data.intra_cluster_churn_caveat }}</p>
      </div>
      {% endif %}
      <p><strong>Caution:</strong> {{ abstract_data.closing_caution }}</p>
    </section>

    <section class="section" id="clusters">
      <div class="section-header">
        <h2>Main Findings</h2>
        <p>The cards below are organized around the research question rather than around raw match labels. Changed themes come first because they carry the substantive answer; stable baselines come second because they show where disclosure language stayed mostly within older legal frames.</p>
      </div>
      {% if not emergent_cards %}
      <div class="empty-note" style="margin-bottom: 18px;">No narrated cluster was judged wholly new in this run. The central result is therefore not the appearance of detached post-only themes, but the splitting, sharpening, and content-shifting of older disclosure families.</div>
      {% endif %}
      <div class="subsection-head">
        <h3>What Changed Most After 2022</h3>
        <p>These are the clusters where the evidence suggests substantive change: either a clearer structural shift, a split/refined subtheme, or a stable thematic family whose post-2022 contents became noticeably more explicit.</p>
      </div>
      {% if finding_cards %}
      <div class="clusters">
        {% for cluster in finding_cards %}
        {{ render_cluster_card(cluster) }}
        {% endfor %}
      </div>
      {% else %}
      <div class="empty-note">No narrated clusters were judged to carry a meaningful post-2022 change signal in the current synthesis.</div>
      {% endif %}

      <div class="subsection-head" style="margin-top:22px;">
        <h3>Stable Baselines and Controls</h3>
        <p>These clusters matter because they show what did not change very much. They function as controls against over-reading the post-2022 count gap as pure novelty.</p>
      </div>
      {% if baseline_cards %}
      <div class="clusters">
        {% for cluster in baseline_cards %}
        {{ render_cluster_card(cluster) }}
        {% endfor %}
      </div>
      {% else %}
      <div class="empty-note">No narrated clusters were judged to function mainly as stable baselines in this run.</div>
      {% endif %}
    </section>

    <section class="section" id="appendix">
      <div class="section-header">
        <h2>Method Appendix</h2>
        <p>This appendix keeps only the figures that clarify the method and support the main interpretation: one shared map, the separate pre/post cluster spaces, and a compact matching summary.</p>
      </div>
      <div class="subsection-head">
        <h3>Shared Embedding Space, Separate Discovery</h3>
        <p>The same embedding space is used for both periods, but cluster discovery is run separately so the method can detect thematic splitting, refinement, and newly explicit subthemes instead of forcing one global cluster map.</p>
      </div>
      <div class="grid-2">
        <div class="figure-card" style="grid-column: 1 / -1;">{{ figures.shared_umap_period | safe }}</div>
        <div class="figure-card">{{ figures.pre_cluster_space | safe }}</div>
        <div class="figure-card">{{ figures.post_cluster_space | safe }}</div>
      </div>
      <div class="subsection-head" style="margin-top: 22px;">
        <h3>Approximate Pre/Post Matching</h3>
        <p>Approximate matching is used to ask which post clusters look persistent, split/refined, or merged relative to the pre system. It informs interpretation, but it is not treated as proof of one-to-one cluster identity.</p>
      </div>
      <div class="grid-2">
        <div class="figure-card" style="grid-column: 1 / -1;">{{ figures.post_match_status | safe }}</div>
      </div>
    </section>

    <section class="section" id="catalog">
      <div class="section-header">
        <h2>Compact catalog</h2>
        <p>A short index of the narrated clusters and Gemini’s abstract-ready sentence for each one.</p>
      </div>
      <details>
        <summary>{{ cluster_cards | length }} narrated clusters</summary>
        <div class="clusters" style="margin-top: 16px;">
          {% for cluster in finding_cards + baseline_cards %}
          <article class="cluster-card" data-kind="{{ cluster.match_type }}">
            <div class="cluster-head">
              <h3>{{ cluster.post_cluster_label }}</h3>
              <div class="cluster-meta">{{ cluster.match_label }}</div>
            </div>
            <div class="cluster-text"><strong>Abstract sentence</strong> {{ cluster.analysis.abstract_candidate_sentence }}</div>
            <div class="cluster-text"><strong>Change reading</strong> {{ cluster.continuity_label }}</div>
            <div class="cluster-text"><strong>Count-gap role</strong> {{ cluster.count_gap_role_label }}</div>
            <div class="cluster-text"><strong>Support IDs</strong> {{ cluster.analysis.supporting_example_ids | join(", ") }}</div>
          </article>
          {% endfor %}
        </div>
      </details>
    </section>

    <p class="footer">
      Source dataset <code>{{ source_dataset }}</code><br>
      This report is still exploratory. Gemini is being used as an evidence-constrained analytical writer, not as a source of independent facts.
    </p>
  </div>

  <script>
  (function() {
    var links = document.querySelectorAll('.nav a');
    var sections = document.querySelectorAll('.hero[id], .abstract-card[id], .section[id]');
    var map = {};
    links.forEach(function(link) { map[link.getAttribute('href').slice(1)] = link; });
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && map[entry.target.id]) {
          links.forEach(function(link) { link.classList.remove('active'); });
          map[entry.target.id].classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -65% 0px' });
    sections.forEach(function(section) { observer.observe(section); });
  })();
  </script>
</body>
</html>
