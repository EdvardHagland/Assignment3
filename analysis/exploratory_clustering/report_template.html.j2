<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ title }}</title>
  <script>{{ plotly_js | safe }}</script>
  <style>
    /* ═══════════════════════════════════════════════
       Design tokens
       ═══════════════════════════════════════════════ */
    :root {
      --ink:       #1a2a35;
      --ink-soft:  #3a4d5c;
      --muted:     #6b7f8e;
      --faint:     #94a5b1;
      --paper:     #f6f2ea;
      --card:      #fffdf9;
      --line:      #ddd1be;
      --line-soft: #ebe3d5;
      --accent:    #0f4c5c;
      --accent-l:  #1b8a9e;
      --warm:      #c56b3c;
      --olive:     #5a8a3e;
      --shadow-sm: 0 1px 3px rgba(19,33,44,0.05);
      --shadow:    0 2px 6px rgba(19,33,44,0.04), 0 8px 24px rgba(19,33,44,0.06);
      --shadow-lg: 0 4px 12px rgba(19,33,44,0.05), 0 16px 40px rgba(19,33,44,0.08);
      --r:         18px;
      --r-lg:      24px;
    }

    /* ═══════════════════════════════════════════════
       Reset & base
       ═══════════════════════════════════════════════ */
    *, *::before, *::after { box-sizing: border-box; margin: 0; }

    html { scroll-behavior: smooth; scroll-padding-top: 56px; }

    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--ink);
      background: var(--paper);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ═══════════════════════════════════════════════
       Top accent bar
       ═══════════════════════════════════════════════ */
    .accent-bar {
      height: 3px;
      background: linear-gradient(90deg, var(--accent) 0%, var(--accent-l) 50%, var(--warm) 100%);
    }

    /* ═══════════════════════════════════════════════
       Sticky nav
       ═══════════════════════════════════════════════ */
    .report-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 2px;
      padding: 0 16px;
      height: 44px;
      background: rgba(246,242,234,0.88);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--line-soft);
      overflow-x: auto;
      scrollbar-width: none;
    }
    .report-nav::-webkit-scrollbar { display: none; }

    .report-nav a {
      flex-shrink: 0;
      padding: 5px 12px;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      transition: background 0.2s, color 0.2s;
    }
    .report-nav a:hover   { background: rgba(15,76,92,0.08); color: var(--accent); }
    .report-nav a.active   { background: var(--accent); color: #fff; }

    /* ═══════════════════════════════════════════════
       Page container
       ═══════════════════════════════════════════════ */
    .page {
      max-width: 1320px;
      margin: 0 auto;
      padding: 28px 24px 80px;
    }

    /* ═══════════════════════════════════════════════
       Hero
       ═══════════════════════════════════════════════ */
    .hero {
      position: relative;
      padding: 48px 52px 44px;
      border-radius: var(--r-lg);
      background: linear-gradient(145deg, var(--card) 0%, #f8f2e4 100%);
      border: 1px solid var(--line);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
    }

    /* left accent stripe */
    .hero::before {
      content: "";
      position: absolute;
      top: 0; left: 0; bottom: 0;
      width: 4px;
      background: linear-gradient(180deg, var(--accent), var(--accent-l));
      border-radius: var(--r-lg) 0 0 var(--r-lg);
    }

    /* decorative blob */
    .hero::after {
      content: "";
      position: absolute;
      right: -60px; bottom: -80px;
      width: 260px; height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(15,76,92,0.07), transparent 65%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-block;
      padding: 5px 13px;
      border-radius: 999px;
      background: rgba(15,76,92,0.08);
      color: var(--accent);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }

    h1 {
      margin-top: 14px;
      font-family: "Source Serif 4", Georgia, serif;
      font-size: clamp(1.9rem, 3.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      color: var(--ink);
    }

    .subtitle {
      margin-top: 10px;
      max-width: 62ch;
      color: var(--muted);
      font-size: 1rem;
    }

    /* ── Metric cards ──────────────────────────────── */
    .hero-meta {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: 12px;
      margin-top: 32px;
    }

    .metric-card {
      padding: 14px 16px;
      border-radius: 14px;
      background: var(--card);
      border: 1px solid var(--line-soft);
      box-shadow: var(--shadow-sm);
    }

    .metric-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--muted);
    }

    .metric-value {
      margin-top: 4px;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--accent);
      line-height: 1.15;
    }

    /* ═══════════════════════════════════════════════
       Section cards
       ═══════════════════════════════════════════════ */
    .section {
      margin-top: 20px;
      padding: 32px 36px;
      border-radius: var(--r-lg);
      background: var(--card);
      border: 1px solid var(--line-soft);
      box-shadow: var(--shadow);
    }

    .section-header {
      margin-bottom: 24px;
    }

    .section-header h2 {
      font-family: "Source Serif 4", Georgia, serif;
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--ink);
    }

    .section-header p {
      margin-top: 6px;
      color: var(--muted);
      max-width: 70ch;
      font-size: 0.92rem;
    }

    /* ═══════════════════════════════════════════════
       Method chips
       ═══════════════════════════════════════════════ */
    .method-strip {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 10px;
    }

    .method-chip {
      padding: 14px 16px;
      border-radius: 14px;
      background: rgba(15,76,92,0.04);
      border: 1px solid rgba(15,76,92,0.10);
      font-size: 0.88rem;
      line-height: 1.5;
    }

    .method-chip strong {
      display: block;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent);
      margin-bottom: 2px;
    }

    /* ═══════════════════════════════════════════════
       Figure grid
       ═══════════════════════════════════════════════ */
    .grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .figure-card {
      padding: 16px;
      border-radius: var(--r);
      background: var(--card);
      border: 1px solid var(--line-soft);
      overflow: hidden;
    }

    .figure-card.full { grid-column: 1 / -1; }

    .figure-note {
      margin: 0 0 8px;
      padding-left: 2px;
      font-size: 0.84rem;
      font-style: italic;
      color: var(--faint);
    }

    /* make plotly charts fill their container */
    .figure-card .plotly-graph-div {
      width: 100% !important;
    }

    /* ═══════════════════════════════════════════════
       Cluster cards
       ═══════════════════════════════════════════════ */
    .clusters {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
      gap: 16px;
    }

    .cluster-card {
      display: flex;
      flex-direction: column;
      padding: 24px;
      border-radius: var(--r);
      background: var(--card);
      border: 1px solid var(--line-soft);
      border-top: 3px solid var(--line);
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.2s;
    }
    .cluster-card:hover { box-shadow: var(--shadow); }

    /* status color coding via top border */
    .cluster-card[data-status="notable"]  { border-top-color: var(--accent); }
    .cluster-card[data-status="filtered"] { border-top-color: var(--warm); }
    .cluster-card[data-status="noise"]    { border-top-color: #b5bec6; opacity: 0.80; }

    .cluster-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .cluster-head h3 {
      font-family: "Inter", sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
    }

    .cluster-size {
      flex-shrink: 0;
      text-align: right;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--muted);
      line-height: 1.45;
    }

    .cluster-status-badge {
      display: inline-block;
      margin-top: 8px;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    [data-status="notable"]  .cluster-status-badge { background: rgba(15,76,92,0.10); color: var(--accent); }
    [data-status="filtered"] .cluster-status-badge { background: rgba(197,107,60,0.10); color: var(--warm); }
    [data-status="noise"]    .cluster-status-badge { background: rgba(107,127,142,0.10); color: var(--muted); }

    /* ── Delta: the headline number ────────────────
       This is the single most important stat per card,
       so it comes right after the header and is large. */
    .delta-row {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin: 14px 0 16px;
      padding: 12px 16px;
      border-radius: 14px;
      background: rgba(90,138,62,0.07);
    }
    .delta-row.negative { background: rgba(197,107,60,0.07); }

    .delta-number {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--olive);
      line-height: 1;
    }
    .delta-row.negative .delta-number { color: var(--warm); }

    .delta-label {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--muted);
    }

    /* ── Share boxes ────────────────────────────────  */
    .shares {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
      margin-bottom: 14px;
    }

    .share-box {
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(15,76,92,0.04);
    }

    .share-box strong {
      display: block;
      font-size: 0.66rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--faint);
      margin-bottom: 1px;
    }

    .share-box span {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--ink);
    }

    /* ── Terms & tickers ───────────────────────────  */
    .cluster-tags {
      margin-bottom: 10px;
      font-size: 0.86rem;
      color: var(--ink-soft);
      line-height: 1.55;
    }

    .cluster-tags strong {
      color: var(--muted);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* ── Example quotes ────────────────────────────  */
    .examples { display: grid; gap: 8px; margin-top: auto; padding-top: 10px; }

    .example {
      padding: 12px 14px;
      border-radius: 12px;
      background: var(--paper);
      border-left: 3px solid var(--line);
    }

    [data-status="notable"]  .example { border-left-color: var(--accent); }
    [data-status="filtered"] .example { border-left-color: var(--warm); }

    .example-meta {
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--faint);
    }

    .example p {
      margin-top: 4px;
      font-size: 0.86rem;
      color: var(--ink-soft);
      line-height: 1.5;
    }

    /* ═══════════════════════════════════════════════
       Catalog collapse
       ═══════════════════════════════════════════════ */
    .catalog-toggle {
      display: block;
      width: 100%;
      padding: 14px 20px;
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      background: var(--card);
      cursor: pointer;
      font-family: inherit;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--accent);
      text-align: left;
      transition: background 0.15s;
    }
    .catalog-toggle:hover { background: rgba(15,76,92,0.04); }
    .catalog-toggle::after {
      content: " ▸ Click to expand";
      font-weight: 400;
      color: var(--faint);
      font-size: 0.82rem;
    }
    details[open] .catalog-toggle::after {
      content: " ▾ Click to collapse";
    }

    /* ═══════════════════════════════════════════════
       Footer
       ═══════════════════════════════════════════════ */
    .footer {
      margin-top: 28px;
      text-align: center;
      font-size: 0.82rem;
      color: var(--faint);
    }

    .footer code {
      font-family: "SF Mono", "Cascadia Code", Consolas, monospace;
      font-size: 0.85em;
      background: rgba(15,76,92,0.06);
      padding: 2px 6px;
      border-radius: 4px;
    }

    /* ═══════════════════════════════════════════════
       Responsive
       ═══════════════════════════════════════════════ */
    @media (max-width: 900px) {
      .page     { padding: 16px 12px 60px; }
      .hero     { padding: 28px 24px 24px; }
      .section  { padding: 22px 20px; }
      .grid-2   { grid-template-columns: 1fr; }
      .clusters { grid-template-columns: 1fr; }
      .hero-meta { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
    }

    /* ═══════════════════════════════════════════════
       Print
       ═══════════════════════════════════════════════ */
    @media print {
      .report-nav, .accent-bar { display: none; }
      .section, .hero { break-inside: avoid; box-shadow: none; border: 1px solid #ccc; }
      .cluster-card { break-inside: avoid; }
      details[open] > .clusters { display: grid !important; }
    }
  </style>
</head>
<body>

  <div class="accent-bar"></div>

  <nav class="report-nav" id="nav">
    <a href="#overview">Overview</a>
    <a href="#method">Method</a>
    <a href="#corpus">Corpus</a>
    <a href="#space">Embeddings</a>
    <a href="#signal">Signal</a>
    <a href="#highlighted">Clusters</a>
    <a href="#catalog">Catalog</a>
  </nav>

  <div class="page">

    <!-- ────────── Hero ────────── -->
    <section class="hero" id="overview">
      <div class="eyebrow">Exploratory report</div>
      <h1>{{ title }}</h1>
      <p class="subtitle">{{ subtitle }}</p>
      <div class="hero-meta">
        <div class="metric-card"><div class="metric-label">Full corpus</div><div class="metric-value">{{ summary.full_rows }}</div></div>
        <div class="metric-card"><div class="metric-label">Sample</div><div class="metric-value">{{ summary.sample_rows }}</div></div>
        <div class="metric-card"><div class="metric-label">Display sample</div><div class="metric-value">{{ summary.display_rows }}</div></div>
        <div class="metric-card"><div class="metric-label">Companies</div><div class="metric-value">{{ summary.companies }}</div></div>
        <div class="metric-card"><div class="metric-label">Clusters</div><div class="metric-value">{{ summary.clusters_found }}</div></div>
        <div class="metric-card"><div class="metric-label">Noise</div><div class="metric-value">{{ summary.noise_share }}</div></div>
        <div class="metric-card"><div class="metric-label">Embedding</div><div class="metric-value" style="font-size:0.88rem; line-height:1.3; margin-top:6px;">{{ summary.model_name }}</div></div>
      </div>
    </section>

    <!-- ────────── Method ────────── -->
    <section class="section" id="method">
      <div class="section-header">
        <h2>Method at a glance</h2>
        <p>Full corpus for descriptive counts; a balanced pre/post-2022 sample for embedding-based clustering.</p>
      </div>
      <div class="method-strip">
        <div class="method-chip"><strong>Corpus</strong>SEC 10-K Item 1A risk disclosures, primes + suppliers</div>
        <div class="method-chip"><strong>Embedding</strong>{{ model_name }}</div>
        <div class="method-chip"><strong>Clustering</strong>UMAP &rarr; dense space &rarr; HDBSCAN</div>
        <div class="method-chip"><strong>Sample</strong>Up to {{ sample_per_period }} rows per period bucket</div>
      </div>
    </section>

    <!-- ────────── Corpus ────────── -->
    <section class="section" id="corpus">
      <div class="section-header">
        <h2>Corpus structure</h2>
        <p>What the corpus looks like before any clustering.</p>
      </div>
      <div class="grid-2">
        <div class="figure-card">
          <p class="figure-note">Full corpus volume by year — post-2022 side is larger, but the clustering sample is balanced.</p>
          {{ figures.corpus_overview | safe }}
        </div>
        <div class="figure-card">
          <p class="figure-note">The balanced sample the clustering model actually sees.</p>
          {{ figures.sample_mix | safe }}
        </div>
      </div>
    </section>

    <!-- ────────── Embedding space ────────── -->
    <section class="section" id="space">
      <div class="section-header">
        <h2>Embedding space</h2>
        <p>2-D UMAP projection — first colored by period, then by emergent cluster.</p>
      </div>
      <div class="grid-2">
        <div class="figure-card full">{{ figures.umap_period | safe }}</div>
        <div class="figure-card full">{{ figures.umap_cluster | safe }}</div>
      </div>
    </section>

    <!-- ────────── Comparative signal ────────── -->
    <section class="section" id="signal">
      <div class="section-header">
        <h2>Comparative cluster signal</h2>
        <p>Where cluster composition differs most across time and the prime–supplier split.</p>
      </div>
      <div class="grid-2">
        <div class="figure-card">{{ figures.cluster_period | safe }}</div>
        <div class="figure-card">{{ figures.cluster_layer | safe }}</div>
        <div class="figure-card full">{{ figures.cluster_year_heatmap | safe }}</div>
      </div>
    </section>

    <!-- ────────── Highlighted clusters ────────── -->
    <section class="section" id="highlighted">
      <div class="section-header">
        <h2>Highlighted clusters</h2>
        <p>The most analytically promising broad-shift clusters. Cards are ordered by shift magnitude.</p>
      </div>

      <div class="clusters">
        {% for cluster in cluster_cards %}
        {% if cluster.status == "Notable broad shift" %}{% set status_key = "notable" %}{% elif cluster.status == "Noise" %}{% set status_key = "noise" %}{% else %}{% set status_key = "filtered" %}{% endif %}
        <article class="cluster-card" data-status="{{ status_key }}" id="cluster-{{ cluster.cluster_label }}">
          <div class="cluster-head">
            <h3>{{ cluster.cluster_label }}</h3>
            <div class="cluster-size">{{ cluster.cluster_size }} rows<br>{{ cluster.ticker_count }} tickers</div>
          </div>
          <span class="cluster-status-badge">{{ cluster.status }}</span>

          <div class="delta-row {% if cluster.delta < 0 %}negative{% endif %}">
            <div class="delta-number">{% if cluster.delta >= 0 %}+{% endif %}{{ "%.1f"|format(cluster.delta * 100) }}<small style="font-size:0.55em;font-weight:600;"> pp</small></div>
            <div class="delta-label">post-2022 minus pre-2022 share</div>
          </div>

          <div class="shares">
            <div class="share-box"><strong>Pre-2022</strong><span>{{ "%.1f"|format(cluster.pre_share * 100) }}%</span></div>
            <div class="share-box"><strong>Post-2022</strong><span>{{ "%.1f"|format(cluster.post_share * 100) }}%</span></div>
            <div class="share-box"><strong>Prime</strong><span>{{ "%.1f"|format(cluster.prime_share * 100) }}%</span></div>
            <div class="share-box"><strong>Supplier</strong><span>{{ "%.1f"|format(cluster.supplier_share * 100) }}%</span></div>
          </div>

          <p class="cluster-tags">{{ cluster.top_terms }}</p>
          {% if cluster.top_tickers %}
          <p class="cluster-tags"><strong>Top tickers</strong> {{ cluster.top_tickers }}</p>
          {% endif %}

          <div class="examples">
            {% for example in cluster.examples %}
            <div class="example">
              <div class="example-meta">{{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }} · {{ example.period_bucket }}</div>
              <p>{{ example.text }}</p>
            </div>
            {% endfor %}
          </div>
        </article>
        {% endfor %}
      </div>
    </section>

    <!-- ────────── Full catalog (collapsible) ────────── -->
    <section class="section" id="catalog">
      <div class="section-header">
        <h2>Full cluster catalog</h2>
        <p>Every cluster kept for documentation — notable movers first, then filtered and noise.</p>
      </div>

      <details>
        <summary class="catalog-toggle">{{ all_cluster_cards | length }} clusters total</summary>
        <div class="clusters" style="margin-top: 16px;">
          {% for cluster in all_cluster_cards %}
          {% if cluster.status == "Notable broad shift" %}{% set status_key = "notable" %}{% elif cluster.status == "Noise" %}{% set status_key = "noise" %}{% else %}{% set status_key = "filtered" %}{% endif %}
          <article class="cluster-card" data-status="{{ status_key }}" id="catalog-{{ cluster.cluster_label }}">
            <div class="cluster-head">
              <h3>{{ cluster.cluster_label }}</h3>
              <div class="cluster-size">{{ cluster.cluster_size }} rows<br>{{ cluster.ticker_count }} tickers</div>
            </div>
            <span class="cluster-status-badge">{{ cluster.status }}</span>

            <div class="delta-row {% if cluster.delta < 0 %}negative{% endif %}">
              <div class="delta-number">{% if cluster.delta >= 0 %}+{% endif %}{{ "%.1f"|format(cluster.delta * 100) }}<small style="font-size:0.55em;font-weight:600;"> pp</small></div>
              <div class="delta-label">post − pre share</div>
            </div>

            <div class="shares">
              <div class="share-box"><strong>Pre-2022</strong><span>{{ "%.1f"|format(cluster.pre_share * 100) }}%</span></div>
              <div class="share-box"><strong>Post-2022</strong><span>{{ "%.1f"|format(cluster.post_share * 100) }}%</span></div>
              <div class="share-box"><strong>Prime</strong><span>{{ "%.1f"|format(cluster.prime_share * 100) }}%</span></div>
              <div class="share-box"><strong>Supplier</strong><span>{{ "%.1f"|format(cluster.supplier_share * 100) }}%</span></div>
            </div>

            <p class="cluster-tags">{{ cluster.top_terms }}</p>
            {% if cluster.top_tickers %}
            <p class="cluster-tags"><strong>Top tickers</strong> {{ cluster.top_tickers }}</p>
            {% endif %}

            <div class="examples">
              {% if cluster.examples %}
                {% for example in cluster.examples %}
                <div class="example">
                  <div class="example-meta">{{ example.ticker }} · {{ example.company_layer }} · {{ example.filing_year }} · {{ example.period_bucket }}</div>
                  <p>{{ example.text }}</p>
                </div>
                {% endfor %}
              {% else %}
                <div class="example">
                  <div class="example-meta">No representative example</div>
                  <p>No saved representative snippet for this cluster.</p>
                </div>
              {% endif %}
            </div>
          </article>
          {% endfor %}
        </div>
      </details>
    </section>

    <p class="footer">
      Generated from <code>{{ generated_from }}</code><br>
      Exploratory — intended to guide annotation, hypothesis refinement, and later supervised classification.
    </p>

  </div>

  <!-- ═══════════════════════════════════════════════
       Active nav highlighting via Intersection Observer
       ═══════════════════════════════════════════════ -->
  <script>
  (function() {
    var sections = document.querySelectorAll('.hero[id], .section[id]');
    var navLinks = document.querySelectorAll('.report-nav a');
    if (!sections.length || !navLinks.length) return;

    var map = {};
    navLinks.forEach(function(a) {
      var id = a.getAttribute('href').replace('#','');
      map[id] = a;
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && map[entry.target.id]) {
          navLinks.forEach(function(a) { a.classList.remove('active'); });
          map[entry.target.id].classList.add('active');
        }
      });
    }, { rootMargin: '-20% 0px -60% 0px' });

    sections.forEach(function(s) { observer.observe(s); });
  })();
  </script>

</body>
</html>
